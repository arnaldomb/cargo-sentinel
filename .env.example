# =============================================================================
# Cargo Sentinel — Environment Variables Example
# Copy this file to .env and fill in real values.
# The .env file is gitignored — NEVER commit real secrets.
#
# VPS: /docker/cargo-sentinel/.env (usado pelo docker-compose.vps.yml)
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=cargo_sentinel
DATABASE_URL=postgresql://sentinel:changeme_strong_password@postgres:5432/cargo_sentinel?schema=public

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Garage S3 — ACCESS KEY MUST START WITH "GK" (generate: GK$(openssl rand -hex 12))
# Secret key generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
GARAGE_ACCESS_KEY=GKchangeme0000000000000000
GARAGE_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
GARAGE_DEFAULT_BUCKET=lpr-images
GARAGE_INTERNAL_URL=http://garage:3900
# garage.toml embutido no docker-compose.yml (config inline) — estes dois
# valores preenchem o rpc_secret e o admin_token do Garage.
# Gerar: rand -hex 32 (rpc_secret) / openssl rand -base64 32 (admin_token)
GARAGE_RPC_SECRET=changeme_generate_with_openssl_rand_hex_32
GARAGE_ADMIN_TOKEN=changeme_generate_with_openssl_rand_base64_32
# URL pública do Garage — presigned URLs de download de relatórios
# Produção: https://storage.sentinel.ggtronic.com.br | Local: http://localhost:3900
GARAGE_SERVER_URL=https://storage.sentinel.ggtronic.com.br

# AWS SDK v3 + Garage compatibility (REQUIRED — prevents checksum validation errors)
AWS_REQUEST_CHECKSUM_CALCULATION=when_required
AWS_RESPONSE_CHECKSUM_VALIDATION=when_required

# -----------------------------------------------------------------------------
# URLs públicas
# WEB_PUBLIC_URL: domínio do portal (Auth.js AUTH_URL + THUMBNAIL_PROXY_URL)
# AUTH_COOKIE_DOMAIN: domínio-pai com ponto inicial para compartilhar o cookie
#   de sessão entre portal.* e lpr.* (Socket.IO autentica pelo cookie)
# -----------------------------------------------------------------------------
WEB_PUBLIC_URL=https://portal.ggtronic.com.br
AUTH_COOKIE_DOMAIN=.ggtronic.com.br

# -----------------------------------------------------------------------------
# Auth.js v5 — mesmo secret no web (assina JWT) e api (verifica JWT)
# Generate with: openssl rand -base64 64
# -----------------------------------------------------------------------------
AUTH_SECRET=changeme_generate_with_openssl_rand_base64_64
AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# Next.js — URL pública da API (Socket.IO no browser). Baked no BUILD da imagem
# web (build-arg no GitHub Actions) — mudar aqui só afeta builds locais.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=https://lpr.ggtronic.com.br

# -----------------------------------------------------------------------------
# Z-API (WhatsApp alerts) — provisionado pelo SUPER_ADMIN por empresa em
# /admin/empresas/[id]/whatsapp. Client-Token global opcional, usado como
# fallback quando a empresa não tem um Client-Token próprio.
# -----------------------------------------------------------------------------
ZAPI_CLIENT_TOKEN=changeme_optional_global_zapi_client_token

# -----------------------------------------------------------------------------
# Traefik local (docker-compose.yml apenas — a VPS usa o Traefik compartilhado)
# -----------------------------------------------------------------------------
ACME_EMAIL=dev@localhost
PUBLIC_DOMAIN=localhost
