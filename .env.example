# =============================================================================
# Cargo Sentinel — Environment Variables Example
# Copy this file to .env and fill in real values.
# The .env file is gitignored — NEVER commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (must match packages/database/.env for local dev)
# -----------------------------------------------------------------------------
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=cargo_sentinel
DATABASE_URL=postgresql://sentinel:sentinel@postgres:5432/cargo_sentinel?schema=public

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Garage S3 — ACCESS KEY MUST START WITH "GK" (generate: GK$(openssl rand -hex 16))
# Secret key generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
GARAGE_ACCESS_KEY=GKchangeme0000000000000000000000
GARAGE_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
GARAGE_DEFAULT_BUCKET=lpr-images
GARAGE_BUCKET=lpr-images
GARAGE_REGION=garage
GARAGE_INTERNAL_URL=http://garage:3900
GARAGE_SERVER_URL=https://sentinel.example.com/media

# AWS SDK v3 + Garage compatibility (REQUIRED — prevents checksum validation errors)
AWS_REQUEST_CHECKSUM_CALCULATION=when_required
AWS_RESPONSE_CHECKSUM_VALIDATION=when_required

# -----------------------------------------------------------------------------
# Traefik / TLS
# -----------------------------------------------------------------------------
ACME_EMAIL=admin@example.com
PUBLIC_DOMAIN=sentinel.example.com

# -----------------------------------------------------------------------------
# Auth.js v5 (NextAuth)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=changeme_generate_with_openssl_rand_base64_32
AUTH_URL=https://sentinel.example.com
AUTH_TRUST_HOST=true
NEXTAUTH_URL=https://sentinel.example.com

# -----------------------------------------------------------------------------
# Next.js — internal (Docker network) and public API URLs
# -----------------------------------------------------------------------------
# URL interna da API (Server Components → Express, dentro da rede Docker)
INTERNAL_API_URL=http://api:4000
# URL pública da API (Client Components → Express, via browser)
NEXT_PUBLIC_API_BASE_URL=https://sentinel.example.com

# -----------------------------------------------------------------------------
# Evolution API (WhatsApp alerts) — pin to v2.3.7, do NOT upgrade to 2.4.0+
# EVOLUTION_INSTANCE_NAME: nome da instância WhatsApp criada na Evolution API
# -----------------------------------------------------------------------------
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_SERVER_URL=http://evolution-api:8080
EVOLUTION_API_KEY=changeme_generate_with_openssl_rand_hex_32
EVOLUTION_INSTANCE_NAME=cargo-sentinel
