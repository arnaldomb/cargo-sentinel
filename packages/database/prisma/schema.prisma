generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Direcao {
  ENTRADA
  SAIDA
}

enum Classificacao {
  LIBERADO
  VISITANTE
  ATENCAO
  SUSPEITO
  CRITICO
}

enum EmpresaStatus {
  ATIVO
  SUSPENSO
}

enum Role {
  SUPER_ADMIN
  ADMIN_EMPRESA
  OPERADOR
}

model Empresa {
  id            String        @id @default(cuid())
  nome          String
  cnpj          String        @unique
  status        EmpresaStatus @default(ATIVO)
  createdAt     DateTime      @default(now())
  obras         Obra[]
  cameras       Camera[]
  eventos       Evento[]
  placas        Placa[]
  historico     ClassificacaoHistorico[]
  users         User[]
  configuracoesWhatsapp ConfiguracaoWhatsApp[]
  relatorios            Relatorio[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nome         String
  role         Role     @default(OPERADOR)
  empresaId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  empresa      Empresa? @relation(fields: [empresaId], references: [id])
  historico    ClassificacaoHistorico[]
  relatorios   Relatorio[] @relation("RelatoriosUsuario")

  @@index([empresaId])
  @@index([email])
}

model Placa {
  id                    String         @id @default(cuid())
  numero                String
  empresaId             String
  empresaTransportadora String?
  motorista             String?
  tipoVeiculo           String?
  material              String?
  observacao            String?
  classificacao         Classificacao  @default(VISITANTE)
  obraClassificacaoId   String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  empresa               Empresa        @relation(fields: [empresaId], references: [id])
  obraClassificacao     Obra?          @relation("PlacaClassificacaoObra", fields: [obraClassificacaoId], references: [id])
  eventos               Evento[]
  historico             ClassificacaoHistorico[]

  @@unique([numero, empresaId])
  @@index([empresaId, classificacao])
}

model ClassificacaoHistorico {
  id                String         @id @default(cuid())
  placaId           String
  empresaId         String
  classificacaoDe   Classificacao?
  classificacaoPara Classificacao
  observacao        String?
  usuarioId         String
  createdAt         DateTime       @default(now())
  placa             Placa          @relation(fields: [placaId], references: [id])
  empresa           Empresa        @relation(fields: [empresaId], references: [id])
  usuario           User           @relation(fields: [usuarioId], references: [id])

  @@index([placaId, createdAt(sort: Desc)])
  @@index([empresaId, createdAt(sort: Desc)])
  @@index([usuarioId, createdAt(sort: Desc)])
}

model Obra {
  id                  String               @id @default(cuid())
  nome                String
  endereco            String?
  ativo               Boolean              @default(true)
  empresaId           String
  createdAt           DateTime             @default(now())
  empresa             Empresa              @relation(fields: [empresaId], references: [id])
  cameras             Camera[]
  eventos             Evento[]
  placasClassificadas Placa[]              @relation("PlacaClassificacaoObra")

  @@index([empresaId])
}

model Camera {
  id        String   @id @default(cuid())
  codigoLpr String   @unique
  nome      String?
  ip        String?
  obraId    String
  empresaId String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  obra      Obra     @relation(fields: [obraId], references: [id])
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  eventos   Evento[]

  @@index([empresaId])
  @@index([obraId])
}

model Evento {
  id             String        @id @default(cuid())
  timestamp      DateTime      @default(now())
  placaNumero    String
  placaId        String?
  direcao        Direcao?
  fotoGarageKey  String?
  idempotencyKey String        @unique
  cameraId       String
  obraId         String
  empresaId      String
  classificacao  Classificacao @default(VISITANTE)
  rawPayload     Json?
  placa          Placa?        @relation(fields: [placaId], references: [id])
  camera         Camera        @relation(fields: [cameraId], references: [id])
  obra           Obra          @relation(fields: [obraId], references: [id])
  empresa        Empresa       @relation(fields: [empresaId], references: [id])

  @@index([empresaId, timestamp])
  @@index([empresaId, placaNumero])
  @@index([placaId])
  @@index([obraId, timestamp])
  @@index([cameraId])
  // HISTORY-04: keyset pagination sem full-table scan para histórico de placa
  @@index([empresaId, placaId, timestamp(sort: Desc)])
}

enum WhatsAppInstanciaStatus {
  DESCONECTADO
  AGUARDANDO_QR
  CONECTADO
}

// Configuração de WhatsApp/Z-API por empresa
model ConfiguracaoWhatsApp {
  id                  String                 @id @default(cuid())
  empresaId           String
  ativo               Boolean                @default(true)
  // Z-API — credenciais da instância do cliente
  zapiInstanceId      String?
  zapiToken           String?
  zapiClientToken     String?
  // Status da instância
  whatsappInstStatus  WhatsAppInstanciaStatus @default(DESCONECTADO)
  // Destino: número individual ou grupo
  whatsappDestino     String?
  whatsappGrupoJid    String?
  whatsappGrupoNome   String?
  // Classificações que disparam alertas; vazio = todos
  classificacoesAlerta Classificacao[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  empresa             Empresa                @relation(fields: [empresaId], references: [id])

  @@unique([empresaId])
  @@index([empresaId])
}

// ============================================================
// Relatorio — Async PDF/Excel report generation (REPORTS-01)
// Status lifecycle: PENDENTE → PROCESSANDO → PRONTO | ERRO
// garageKey preenchido quando PRONTO: reports/{empresaId}/{id}.pdf|.xlsx
// ============================================================
enum RelatorioStatus {
  PENDENTE
  PROCESSANDO
  PRONTO
  ERRO
}

model Relatorio {
  id           String          @id @default(cuid())
  empresaId    String
  status       RelatorioStatus @default(PENDENTE)
  formato      String          // "PDF" | "XLSX"
  filtros      Json            // { dataInicio?, dataFim?, obraId?, cameraId?, classificacao?, placa? }
  garageKey    String?         // preenchido quando PRONTO: reports/{empresaId}/{id}.pdf ou .xlsx
  expiresAt    DateTime?       // now() + 1h ao marcar PRONTO (REPORTS-07)
  erroMsg      String?         // preenchido quando ERRO
  criadoPor    String          // userId do solicitante
  criadoEm    DateTime        @default(now())
  atualizadoEm DateTime       @updatedAt
  empresa      Empresa         @relation(fields: [empresaId], references: [id])
  usuario      User            @relation("RelatoriosUsuario", fields: [criadoPor], references: [id])

  @@index([empresaId, criadoEm(sort: Desc)]) // listagem tenant-scoped (REPORTS-01)
  @@index([criadoPor, criadoEm(sort: Desc)]) // filtrar por usuário
}
